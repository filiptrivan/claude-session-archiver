# Copy this file to ".env" and fill in your values.
# .env is git-ignored — NEVER commit real credentials.
#
# Works with any S3-compatible object storage: Cloudflare R2, AWS S3, MinIO,
# Backblaze B2, etc. Use a PRIVATE bucket — session transcripts can contain
# secrets and personal data (see the SECURITY section in the README).

# Full S3 endpoint URL.
#   Cloudflare R2 : https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   AWS S3        : leave blank to use the AWS default for S3_REGION
#   MinIO         : http://localhost:9000
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=claude-sessions

# Optional. Cloudflare R2 ignores region — leave "auto". AWS S3 needs the
# bucket's real region (e.g. eu-central-1).
S3_REGION=auto
